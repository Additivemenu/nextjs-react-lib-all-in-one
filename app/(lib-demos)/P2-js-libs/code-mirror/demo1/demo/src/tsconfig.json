{
  // Compiles the demo's TypeScript source (src/*.ts) into browser-ready
  // ES modules emitted flat into the parent demo/ folder.
  //
  //   npx tsc -p "app/(lib-demos)/P2-js-libs/code-mirror/demo1/demo/src"
  //
  // Relative imports are written WITH the ".js" extension in the .ts files —
  // TypeScript resolves "./foo.js" to "./foo.ts" at check time and emits the
  // specifier verbatim, so the output runs natively in the browser.
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "strict": true,
    "skipLibCheck": true,
    "outDir": ".."
  },
  // explicit list (not "include") because outDir ".." is this folder's
  // parent — tsc auto-excludes the outDir, which would swallow src/ globs
  "files": ["index.ts", "editor.ts", "runner.ts", "slash-commands.ts"]
}
